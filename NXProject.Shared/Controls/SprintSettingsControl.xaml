<UserControl x:Class="NXProject.Controls.SprintSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Sprint"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="Centralize aqui as configuracoes de sprint do projeto. Esta aba ja fica pronta para receber mais regras no futuro."
                           Margin="0,8,0,0"
                           FontSize="13"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <Border Grid.Row="2"
                    Padding="20"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    MaxWidth="560"
                    HorizontalAlignment="Left">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="Sprint inicial"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold"/>
                    <TextBox Grid.Row="0"
                             Grid.Column="1"
                             Width="96"
                             Text="{Binding FirstSprintNumber, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"/>
                    <TextBlock Grid.Row="0"
                               Grid.Column="2"
                               Text="Numero exibido na primeira faixa de sprint do Gantt."
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Text="Dias por sprint"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold"/>
                    <TextBox Grid.Row="2"
                             Grid.Column="1"
                             Width="96"
                             Text="{Binding SprintDurationDays, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"/>
                    <TextBlock Grid.Row="2"
                               Grid.Column="2"
                               Text="Quantidade de dias usada para avancar automaticamente a sprint no cronograma."
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="4"
                               Grid.Column="0"
                               Text="Numeracao"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold"/>
                    <ComboBox Grid.Row="4"
                              Grid.Column="1"
                              Width="110"
                              ItemsSource="{Binding SprintNumberingModes}"
                              SelectedItem="{Binding SprintNumberingMode, Mode=TwoWay}"/>
                    <TextBlock Grid.Row="4"
                               Grid.Column="2"
                               Text="Escolhe se o cronograma avanca as sprints de forma sequencial, apenas par ou apenas impar."
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="6"
                               Grid.Column="0"
                               Text="Baixa até 3 SFP"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold"/>
                    <TextBox Grid.Row="6"
                             Grid.Column="1"
                             Width="96"
                             Text="{Binding LowDaysPerSfp, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"/>
                    <TextBlock Grid.Row="6"
                               Grid.Column="2"
                               Text="Valor usado quando a atividade tem até 3 SFP."
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="8"
                               Grid.Column="0"
                               Text="Media &gt;3 &lt;6"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold"/>
                    <TextBox Grid.Row="8"
                             Grid.Column="1"
                             Width="96"
                             Text="{Binding MediumDaysPerSfp, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"/>
                    <TextBlock Grid.Row="8"
                               Grid.Column="2"
                               Text="Valor usado quando a atividade tem mais de 3 e menos de 6 SFP."
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap"/>

                    <TextBlock Grid.Row="10"
                               Grid.Column="0"
                               Text="Alta >= 6"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold"/>
                    <TextBox Grid.Row="10"
                             Grid.Column="1"
                             Width="96"
                             Text="{Binding HighDaysPerSfp, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"/>
                    <TextBlock Grid.Row="10"
                               Grid.Column="2"
                               Text="Valor usado quando a atividade tem 6 SFP ou mais."
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left">
                <Button Content="Gravar configuracao para novos projetos"
                        Padding="14,8"
                        Command="{Binding SaveSprintSettingsAsDefaultCommand}"/>
                <TextBlock Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Text="Mantem a configuracao atual como padrao local para os proximos projetos."
                           FontSize="12"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           TextWrapping="Wrap"
                           MaxWidth="320"/>
            </StackPanel>

            <Border Grid.Row="6"
                    Padding="16"
                    Background="#F6F8FB"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    MaxWidth="560"
                    HorizontalAlignment="Left">
                <StackPanel>
                    <TextBlock Text="O que é SFP?"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock Margin="0,8,0,0"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap">
                        <Run Text="SFP significa "/>
                        <Run Text="Simple Function Point" FontWeight="SemiBold"/>
                        <Run Text=". É uma forma de medir o tamanho funcional do software a partir das funcionalidades entregues ao usuário, ajudando na estimativa de esforço e duração."/>
                    </TextBlock>
                    <TextBlock Margin="0,8,0,0"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap">
                        <Run Text="Faixas usadas no sistema: "/>
                        <Run Text="Baixa até 3 SFP" FontWeight="SemiBold"/>
                        <Run Text=", "/>
                        <Run Text="Média &gt; 3 e &lt; 6" FontWeight="SemiBold"/>
                        <Run Text=" e "/>
                        <Run Text="Alta &gt;= 6" FontWeight="SemiBold"/>
                        <Run Text="."/>
                    </TextBlock>
                    <TextBlock Margin="0,8,0,0"
                               FontSize="12"
                               Foreground="{StaticResource PrimaryBrush}"
                               TextWrapping="Wrap">
                        <Hyperlink NavigateUri="https://handwiki.org/wiki/The_Simple_Function_Point_%28SFP%29_method"
                                   RequestNavigate="OnRequestNavigate">
                            Ver conceito de SFP na web
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock Margin="0,12,0,0"
                               Text="Espaco reservado para futuras configuracoes, como data-base da sprint, capacidade por sprint, feriados e regras de rollover."
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</UserControl>
